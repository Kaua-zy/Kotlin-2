// click the <icon src="AllIcons.Actions.Execute"/> icon in the gutter.
fun main() {
    val numeros = mutableListOf<Double>()
    var soma = 0.0
    for (i in 1..6) {
        print("Digite o $i número: ")
        val numero = readLine()!!.toDouble()
        numeros.add(numero)

        if (numero < 72) {
            soma += numero
        }
    }


    println("\nNúmeros informados:")
    for (num in numeros) {
        println(num)
    }


    println("\nSoma dos números menores que 72: $soma")
}








